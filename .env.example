# ============================================
# 拓越后端环境变量模板 (.env.example)
# 复制此文件为 .env 并填入真实值
# ============================================

# --------------------------------------------
# 基础配置
# --------------------------------------------
# 运行环境: development | production
ENVIRONMENT=development

# --------------------------------------------
# MySQL 数据库 (Prisma)
# --------------------------------------------
# 格式: mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://username:password@localhost:3306/tuoyue_db_new

# --------------------------------------------
# Redis 缓存
# --------------------------------------------
# 方式1: 直接配置 URL (优先级更高)
REDIS_URL=redis://localhost:6379/0
# 方式2: 分开配置主机和端口
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --------------------------------------------
# JWT 认证
# --------------------------------------------
# 用于签名 JWT Token 的密钥 (生产环境请使用强随机字符串)
JWT_SECRET=your-jwt-secret-key-here

# --------------------------------------------
# OpenAI / AI 引擎
# --------------------------------------------
# OpenAI API Key (从环境变量读取，不再硬编码)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API 基础地址 (可选，默认使用官方地址)
# OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_BASE=http://api.tuoyue-tech.shop/v1

# 默认模型名称 (可选)
OPENAI_MODEL_NAME=gpt-4o-mini

# --------------------------------------------
# 支付宝支付
# --------------------------------------------
# 支付宝应用 ID
ALIPAY_APP_ID=your-alipay-app-id

# 支付宝私钥 (RSA2 私钥，每行64字符，或单行字符串)
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQE...
-----END RSA PRIVATE KEY-----

# 支付宝公钥 (支付宝提供的公钥)
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----

# 支付回调地址 (外网可访问)
ALIPAY_NOTIFY_URL=https://api.tuoyue-tech.icu/api/order/webhook

# 支付完成跳转地址 (前端页面)
ALIPAY_RETURN_URL=https://pofengzhetuoyue.vercel.app/payment/success

# --------------------------------------------
# 阿里云短信服务
# --------------------------------------------
# 阿里云 AccessKey ID
ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id

# 阿里云 AccessKey Secret
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret

# 短信签名 (需在阿里云控制台申请并通过审核)
SMS_SIGN_NAME=破风者

# 短信模板 CODE (如: SMS_12345678)
SMS_TEMPLATE_CODE=SMS_XXXXX
